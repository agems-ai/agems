  type         AgentType   @default(AUTONOMOUS)
  description  String      @db.Text
  systemPrompt String      @map("system_prompt") @db.Text
  mission      String?     @db.Text
  llmProvider  LLMProvider @map("llm_provider")
  llmModel     String      @map("llm_model")
  llmConfig    Json        @default("{}") @map("llm_config")
  runtimeConfig Json       @default("{}") @map("runtime_config")
  values       Json?
  metadata     Json?
  tags         String[]    @default([])
  toolSlugs    String[]    @default([]) @map("tool_slugs")
  skillSlugs   String[]    @default([]) @map("skill_slugs")
  authorOrg    String      @map("author_org")
  authorEmail  String?     @map("author_email")
  downloads    Int         @default(0)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("catalog_agents")
}

model CatalogSkill {
  id           String    @id @default(uuid())
  slug         String    @unique
  name         String
  description  String    @db.Text
  content      String    @default("") @db.Text
  version      String    @default("1.0.0")
  type         SkillType @default(CUSTOM)
  entryPoint   String    @default("") @map("entry_point")
  configSchema Json?     @map("config_schema")
  tags         String[]  @default([])
  authorOrg    String    @map("author_org")
  authorEmail  String?   @map("author_email")
  downloads    Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("catalog_skills")
}

model CatalogTool {
  id             String    @id @default(uuid())
  slug           String    @unique
  name           String
  description    String    @db.Text
  type           ToolType
  configTemplate Json      @default("{}") @map("config_template")
  authType       AuthType? @map("auth_type")
  tags           String[]  @default([])
  authorOrg      String    @map("author_org")
  authorEmail    String?   @map("author_email")
  downloads      Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("catalog_tools")
}

// ═══════════════════════════════════════════════════
// SETTINGS (Key-Value Store)
// ═══════════════════════════════════════════════════

model Setting {
  id        String        @id @default(uuid())
  orgId     String?       @map("org_id")
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  key       String
  value     String        @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@unique([orgId, key])
  @@map("settings")
}

// ═══════════════════════════════════════════════════
// GOALS (Hierarchical Goal System)
// ═══════════════════════════════════════════════════

model Goal {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title       String
  description String?      @db.Text
  status      GoalStatus   @default(PLANNED)
  priority    Priority     @default(MEDIUM)

  // Hierarchy
  parentId String? @map("parent_id")
  parent   Goal?   @relation("GoalTree", fields: [parentId], references: [id])
  children Goal[]  @relation("GoalTree")

  // Ownership
  ownerType ActorType @map("owner_type")
  ownerId   String    @map("owner_id")
  agentId   String?   @map("agent_id")
  agent     Agent?    @relation(fields: [agentId], references: [id])

  // Project linkage
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id])

  // Progress
  progress   Int       @default(0) // 0-100
  targetDate DateTime? @map("target_date")
  achievedAt DateTime? @map("achieved_at")

  tasks     Task[]
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId, status])
  @@index([parentId])
  @@index([ownerType, ownerId])
  @@map("goals")
}

enum GoalStatus {
  PLANNED
  ACTIVE
  ACHIEVED
  CANCELLED
  PAUSED
}

// ═══════════════════════════════════════════════════
// PROJECTS
// ═══════════════════════════════════════════════════

model Project {
  id          String        @id @default(uuid())
  orgId       String        @map("org_id")
  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(PLANNED)
  priority    Priority      @default(MEDIUM)

  // Lead
  leadType ActorType @map("lead_type")
  leadId   String    @map("lead_id")

  // Dates
  startDate  DateTime? @map("start_date")
  targetDate DateTime? @map("target_date")
  completedAt DateTime? @map("completed_at")

  // Progress
  progress Int @default(0) // 0-100

  tasks    Task[]
  goals    Goal[]
  metadata Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId, status])
  @@map("projects")
}

enum ProjectStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

// ═══════════════════════════════════════════════════
// AGENT BUDGETS & COST CONTROL
// ═══════════════════════════════════════════════════

model AgentBudget {
  id      String @id @default(uuid())
  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Monthly budget (USD)
  monthlyLimitUsd Float  @map("monthly_limit_usd")
  currentSpendUsd Float  @default(0) @map("current_spend_usd")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")

  // Alerts
  softAlertPercent  Int     @default(80) @map("soft_alert_percent")  // Alert at 80% spend
  hardStopEnabled   Boolean @default(true) @map("hard_stop_enabled") // Auto-pause at 100%
  alertSent         Boolean @default(false) @map("alert_sent")
  hardStopTriggered Boolean @default(false) @map("hard_stop_triggered")

  incidents BudgetIncident[]
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([periodStart, periodEnd])
  @@map("agent_budgets")
}

model BudgetIncident {
  id       String @id @default(uuid())
  budgetId String @map("budget_id")
  budget   AgentBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  type     BudgetIncidentType
  message  String    @db.Text
  spendUsd Float     @map("spend_usd")
  limitUsd Float     @map("limit_usd")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([budgetId])
  @@map("budget_incidents")
}

enum BudgetIncidentType {
  SOFT_ALERT
  HARD_STOP
  BUDGET_RESET
  MANUAL_OVERRIDE
}

// ═══════════════════════════════════════════════════
// AGENT CONFIG REVISIONS
// ═══════════════════════════════════════════════════

model AgentConfigRevision {
  id      String @id @default(uuid())
  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  version     Int
  changeset   Json       // { field: { old: value, new: value } }
  snapshot    Json       // Full config snapshot at this version
  changedBy   ActorType  @map("changed_by")
  changedById String     @map("changed_by_id")
  changeNote  String?    @map("change_note") @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")

  @@unique([agentId, version])
  @@index([agentId])
  @@map("agent_config_revisions")
}

// ═══════════════════════════════════════════════════
// TASK LABELS
// ═══════════════════════════════════════════════════

model Label {
  id    String       @id @default(uuid())
  orgId String       @map("org_id")
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name  String
  color String       @default("#6c5ce7") // Hex color
  tasks TaskLabel[]

  @@unique([orgId, name])
  @@map("labels")
}

model TaskLabel {
  id      String @id @default(uuid())
  taskId  String @map("task_id")
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId String @map("label_id")
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@map("task_labels")
}

// ═══════════════════════════════════════════════════
// TASK ATTACHMENTS
// ═══════════════════════════════════════════════════

model TaskAttachment {
  id           String    @id @default(uuid())
  taskId       String    @map("task_id")
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename     String
  originalName String    @map("original_name")
  mimetype     String
  size         Int
  url          String
  uploadedBy   ActorType @map("uploaded_by")
  uploaderId   String    @map("uploader_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([taskId])
  @@map("task_attachments")
}

// ═══════════════════════════════════════════════════
// TASK WORK PRODUCTS
// ═══════════════════════════════════════════════════

model TaskWorkProduct {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  type        WorkProductType @default(ARTIFACT)
  content     String?  @db.Text  // Text content or URL
  metadata    Json?
  createdBy   ActorType @map("created_by")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([taskId])
  @@map("task_work_products")
}

enum WorkProductType {
  ARTIFACT
  DOCUMENT
  CODE
  REPORT
  FILE
}

// ═══════════════════════════════════════════════════
// TASK READ STATES (Inbox)
// ═══════════════════════════════════════════════════

model TaskReadState {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  readAt DateTime @default(now()) @map("read_at")

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_read_states")
}

// ═══════════════════════════════════════════════════
// APPROVAL COMMENTS
// ═══════════════════════════════════════════════════

model ApprovalComment {
  id         String          @id @default(uuid())
  requestId  String          @map("request_id")
  request    ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorType ActorType       @map("author_type")
  authorId   String          @map("author_id")
  content    String          @db.Text
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([requestId])
  @@map("approval_comments")
}

// ═══════════════════════════════════════════════════
// AGENT API KEYS
// ═══════════════════════════════════════════════════

model AgentApiKey {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name      String
  keyHash   String   @map("key_hash")     // bcrypt hash of key
  keyPrefix String   @map("key_prefix")   // First 8 chars for identification
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([agentId])
  @@index([keyPrefix])
  @@map("agent_api_keys")
}

// ═══════════════════════════════════════════════════
// PLUGIN SYSTEM
// ═══════════════════════════════════════════════════

model Plugin {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  slug        String       @unique
  description String?      @db.Text
  version     String
  author      String?
  homepage    String?
  entryPoint  String       @map("entry_point")
  config      Json?
  enabled     Boolean      @default(true)
  installedAt DateTime     @default(now()) @map("installed_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("plugins")
}

// ── Repositories ──

model Repository {
  id             String          @id @default(uuid())
  orgId          String          @map("org_id")
  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  gitUrl         String          @map("git_url")
  branch         String          @default("main")
  localPath      String?         @map("local_path")
  syncSchedule   String?         @map("sync_schedule")
  syncStatus     RepoSyncStatus  @default(PENDING) @map("sync_status")
  lastSyncAt     DateTime?       @map("last_sync_at")
  lastSyncError  String?         @map("last_sync_error")
  authType       RepoAuthType    @default(NONE) @map("auth_type")
  authConfig     Json?           @map("auth_config")
  excludes       String?
  description    String?
  metadata       Json?
  agents         AgentRepository[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("repositories")
}

model AgentRepository {
  id       String     @id @default(uuid())
  agentId  String     @map("agent_id")
  agent    Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  repoId   String     @map("repo_id")
  repo     Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  enabled  Boolean    @default(true)

  @@unique([agentId, repoId])
  @@map("agent_repositories")
}

enum RepoSyncStatus {
  PENDING
  CLONING
  SYNCING
  SYNCED
  ERROR
}

enum RepoAuthType {
  NONE
  SSH_KEY
  TOKEN
  BASIC
}
