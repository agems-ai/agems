{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@agems/shared": ["../../packages/shared/src"],
      "@agems/shared/*": ["../../packages/shared/src/*"],
      "@agems/ai": ["../../packages/ai/src"],
      "@agems/ai/*": ["../../packages/ai/src/*"],
      "@agems/db": ["../../packages/db/src"],
      "@agems/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/ai/src/**/*",
    "../../packages/db/src/**/*"
  ]
}
